# Server (PORT = API server listen port)
NODE_ENV=development
PORT=3000
API_VERSION=v1

# Database (MySQL)
DB_HOST=localhost
DB_PORT=3306
DB_NAME=company_miner_db
DB_USER=root
DB_PASSWORD=
DB_POOL_MIN=2
DB_POOL_MAX=10

# JWT
JWT_SECRET=change-me-in-production-min-32-chars
JWT_EXPIRES_IN=24h
JWT_REFRESH_SECRET=change-me-refresh-in-production
JWT_REFRESH_EXPIRES_IN=7d

# AI provider for Company Miner (openai | gemini)
AI_PROVIDER=gemini

# OpenAI (when AI_PROVIDER=openai)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Google Gemini (when AI_PROVIDER=gemini)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
GEMINI_MAX_OUTPUT_TOKENS_MAIN=4096
GEMINI_MAX_OUTPUT_TOKENS_DEFAULT=2048
GEMINI_REQUEST_TIMEOUT_MS=120000

# Company Miner enrichment (set false to reduce Gemini API calls / cost)
COMPANY_MINER_PUBLIC_SEARCH_ENRICH=true
COMPANY_MINER_INDUSTRY_PEER_SEARCH=true
COMPANY_MINER_DEEP_SEARCH=true

# CORS (frontend origin; use same host:port as frontend dev/server)
CORS_ORIGIN=http://localhost:3001

# Optional: absolute path to logo used in PDF reports
# COMPANY_LOGO_PATH=/var/www/html/hackathon2.0/backend-company-miner/assets/company-logo.png

# Rate limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=5000

# Logging
LOG_LEVEL=info

# Zoho CRM integration (Company Miner → attachment upload)
ZOHO_CLIENT_ID=
ZOHO_CLIENT_SECRET=
ZOHO_REFRESH_TOKEN=
ZOHO_API_BASE=https://www.zohoapis.com
ZOHO_ACCOUNTS_URL=https://accounts.zoho.com
ZOHO_INTEGRATION_API_KEY=
ZOHO_WORKER_ENABLED=true
ZOHO_WORKER_POLL_INTERVAL_MS=5000
ZOHO_JOB_IDEMPOTENCY_WINDOW_MS=1800000
ZOHO_WORKER_CONCURRENCY=1
ZOHO_JOB_STALE_PROCESSING_MS=900000
ZOHO_JOB_MAX_ATTEMPTS=3
ZOHO_JOB_RETRY_DELAYS_MS=5000,15000,45000

# Optional: override default admin when running seed (npm run seed)
# SEED_ADMIN_EMAIL=admin@companyminer.local
# SEED_ADMIN_PASSWORD=Admin@123
