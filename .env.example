# Server
NODE_ENV=development
PORT=3000
API_VERSION=v1

# Database (MySQL)
DB_HOST=localhost
DB_PORT=3306
DB_NAME=company_miner_db
DB_USER=root
DB_PASSWORD=
DB_POOL_MIN=2
DB_POOL_MAX=10

# JWT
JWT_SECRET=change-me-in-production-min-32-chars
JWT_EXPIRES_IN=24h
JWT_REFRESH_SECRET=change-me-refresh-in-production
JWT_REFRESH_EXPIRES_IN=7d

# OpenAI (required for Company Miner extraction and suggestions)
OPENAI_API_KEY=

# CORS (frontend origin)
CORS_ORIGIN=http://localhost:3001

# Rate limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=5000

# Logging
LOG_LEVEL=info

# Optional: override default admin when running seed (npm run seed)
# SEED_ADMIN_EMAIL=admin@companyminer.local
# SEED_ADMIN_PASSWORD=Admin@123
